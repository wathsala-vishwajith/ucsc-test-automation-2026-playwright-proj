{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "strict": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@client/*": ["tests/client/*"],
      "@helper/*": ["tests/helper/*"],
      "@fixtures/*": ["tests/fixtures/*"],
      "@data/*": ["tests/data/*"],
      "@tests/*": ["tests/*"]
    }
  },
  "include": ["tests/**/*.ts", "playwright.config.ts"],
  "exclude": ["node_modules"]
}
